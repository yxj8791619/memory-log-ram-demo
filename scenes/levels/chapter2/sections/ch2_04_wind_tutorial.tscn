[node name="Hint_WindPath" type="Label" parent="Hints"]
offset_left = 760.0
offset_top = 116.0
offset_right = 1210.0
offset_bottom = 194.0
text = "这一段承接上一段刚解锁的能力：\n先用枪把子弹送进 B 层风道，借高差继续向前追；如果后台炮台压得太狠，再考虑带着护盾切进 B 层。"

[node name="Hint_WindInput" type="Label" parent="Hints"]
offset_left = 352.0
offset_top = 210.0
offset_right = 724.0
